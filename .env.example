# Autonomous Organization environment template.
# Placeholder names only. Do not put real secrets in this file.

# App
NODE_ENV=development
APP_ENV=development
APP_URL=http://localhost:3000
PUBLIC_SITE_URL=http://localhost:3000
BRAND_SPEC_PATH=docs/AUTONOMOUS_ORGANIZATION_BRAND_SPEC.md
TIMEZONE=America/Toronto
PUBLIC_SUPPORT_EMAIL=autonomousorganization@protonmail.com

# Database
DATABASE_URL=postgresql://ao_user:ao_password@localhost:5432/autonomous_organization
ENABLE_DATABASE_READS=false

# Stripe
STRIPE_SECRET_KEY=PLACEHOLDER_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=PLACEHOLDER_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=PLACEHOLDER_STRIPE_WEBHOOK_SECRET
STRIPE_API_VERSION=2026-03-25.dahlia
STRIPE_CHECKOUT_ENABLED=false
STRIPE_TEST_MODE_ONLY=true
STRIPE_CHECKOUT_RESERVATION_MINUTES=31
STRIPE_ALLOWED_SHIPPING_COUNTRIES=US,CA,GB,AU,DE,FR,NL,SE,JP
STRIPE_AUTOMATIC_TAX_ENABLED=false

# Printify
PRINTIFY_API_TOKEN=PLACEHOLDER_PRINTIFY_API_TOKEN
PRINTIFY_SHOP_ID=PLACEHOLDER_PRINTIFY_SHOP_ID

# Discord incoming webhooks
DISCORD_ALERTS_WEBHOOK_URL=PLACEHOLDER_DISCORD_ALERTS_WEBHOOK_URL
DISCORD_OPS_LOG_WEBHOOK_URL=PLACEHOLDER_DISCORD_OPS_LOG_WEBHOOK_URL
DISCORD_DEPLOYS_WEBHOOK_URL=PLACEHOLDER_DISCORD_DEPLOYS_WEBHOOK_URL

# Social platform IDs only; OAuth tokens belong in the secret store.
X_ACCOUNT_ID=PLACEHOLDER_X_ACCOUNT_ID
INSTAGRAM_ACCOUNT_ID=PLACEHOLDER_INSTAGRAM_ACCOUNT_ID
TIKTOK_ACCOUNT_ID=PLACEHOLDER_TIKTOK_ACCOUNT_ID

# Deployment
HETZNER_SERVER_IP=203.0.113.10
SSH_DEPLOY_USER=ao_deploy

# Livestream
LIVESTREAM_ENABLED=false
LIVESTREAM_FALLBACK_SCENE=approved_static_status

# Wallet/token identifiers only. Never store seed phrases or private keys here.
PHANTOM_PUBLIC_ADDRESS=PLACEHOLDER_PHANTOM_PUBLIC_ADDRESS
PUMPFUN_PROFILE_URL=PLACEHOLDER_PUMPFUN_PROFILE_URL
TOKEN_WORK_FROZEN=true
