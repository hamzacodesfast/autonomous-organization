# Copy to /srv/autonomous-organization/app/.env.production on the VPS.
# Real production secrets belong only on the server or in the operator secret store.

NODE_ENV=production
APP_ENV=production
APP_URL=https://autonomousorganization.example
PUBLIC_SITE_URL=https://autonomousorganization.example
PUBLIC_SUPPORT_EMAIL=autonomousorganization@protonmail.com
BRAND_SPEC_PATH=docs/AUTONOMOUS_ORGANIZATION_BRAND_SPEC.md
TIMEZONE=America/Toronto
TOKEN_WORK_FROZEN=true

POSTGRES_DB=autonomous_organization
POSTGRES_USER=ao_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DATABASE_PASSWORD
DATABASE_URL=postgresql://ao_user:REPLACE_WITH_STRONG_DATABASE_PASSWORD@postgres:5432/autonomous_organization
ENABLE_DATABASE_READS=true
HERMES_AGENT_NAME=hermes
HERMES_RUNTIME_ENABLED=true
HERMES_HEARTBEAT_INTERVAL_SECONDS=300
HERMES_KILL_SWITCH=false

STRIPE_SECRET_KEY=sk_live_REPLACE
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE
STRIPE_API_VERSION=2026-03-25.dahlia
STRIPE_CHECKOUT_ENABLED=false
STRIPE_TEST_MODE_ONLY=true
STRIPE_CHECKOUT_RESERVATION_MINUTES=31
STRIPE_ALLOWED_SHIPPING_COUNTRIES=US,CA,GB,AU,DE,FR,NL,SE,JP
STRIPE_AUTOMATIC_TAX_ENABLED=false
STRIPE_REQUIRE_TERMS_CONSENT=false

PRINTIFY_ENABLED=false
PRINTIFY_API_BASE_URL=https://api.printify.com/v1
PRINTIFY_API_TOKEN=REPLACE_WITH_PRINTIFY_TOKEN
PRINTIFY_SHOP_ID=REPLACE_WITH_PRINTIFY_SHOP_ID
PRINTIFY_PRODUCT_ID=69e5bbbbc109d487ac09e911
PRINTIFY_VARIANT_ID_S=12126
PRINTIFY_VARIANT_ID_M=12125
PRINTIFY_VARIANT_ID_L=12124
PRINTIFY_VARIANT_ID_XL=12127
PRINTIFY_VARIANT_ID_XXL=12128
PRINTIFY_SHIPPING_METHOD=1
PRINTIFY_SEND_SHIPPING_NOTIFICATION=false

DISCORD_ALERTS_WEBHOOK_URL=REPLACE_WITH_DISCORD_ALERTS_WEBHOOK
DISCORD_OPS_LOG_WEBHOOK_URL=REPLACE_WITH_DISCORD_OPS_LOG_WEBHOOK
DISCORD_DEPLOYS_WEBHOOK_URL=REPLACE_WITH_DISCORD_DEPLOYS_WEBHOOK
DISCORD_DROPS_PENDING_APPROVAL_WEBHOOK_URL=REPLACE_WITH_DISCORD_DROPS_PENDING_APPROVAL_WEBHOOK
DISCORD_CUSTOMER_ESCALATIONS_WEBHOOK_URL=REPLACE_WITH_DISCORD_CUSTOMER_ESCALATIONS_WEBHOOK
DISCORD_POSTMORTEMS_WEBHOOK_URL=REPLACE_WITH_DISCORD_POSTMORTEMS_WEBHOOK
DISCORD_APPLICATION_ID=REPLACE_WITH_DISCORD_APPLICATION_ID
DISCORD_PUBLIC_KEY=REPLACE_WITH_DISCORD_PUBLIC_KEY
DISCORD_BOT_TOKEN=REPLACE_WITH_DISCORD_BOT_TOKEN
DISCORD_APPROVALS_CHANNEL_ID=REPLACE_WITH_DISCORD_APPROVALS_CHANNEL_ID
DISCORD_DROPS_PENDING_APPROVAL_CHANNEL_ID=REPLACE_WITH_DISCORD_DROPS_PENDING_APPROVAL_CHANNEL_ID
DISCORD_APPROVER_USER_IDS=REPLACE_WITH_COMMA_SEPARATED_DISCORD_USER_IDS

X_ACCOUNT_ID=PLACEHOLDER_X_ACCOUNT_ID
INSTAGRAM_ACCOUNT_ID=PLACEHOLDER_INSTAGRAM_ACCOUNT_ID
TIKTOK_ACCOUNT_ID=PLACEHOLDER_TIKTOK_ACCOUNT_ID

HETZNER_SERVER_IP=62.238.9.164
SSH_DEPLOY_USER=ao_deploy

LIVESTREAM_ENABLED=false
LIVESTREAM_FALLBACK_SCENE=approved_static_status

PHANTOM_PUBLIC_ADDRESS=PLACEHOLDER_PHANTOM_PUBLIC_ADDRESS
PUMPFUN_PROFILE_URL=PLACEHOLDER_PUMPFUN_PROFILE_URL
