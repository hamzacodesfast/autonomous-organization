# Hermes profile environment for the ao-brand production profile.
# Copy to: ~/.hermes/profiles/ao-brand/.env
# The checked-in example is OpenAI-compatible. If the live profile is temporarily
# pointed at Anthropic instead, keep that provider override on the VPS and out of Git.

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
